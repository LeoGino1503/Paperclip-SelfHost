# --- Paperclip app ---
PORT=3100
SERVE_UI=true
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
PAPERCLIP_PUBLIC_URL=http://localhost:3100
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32

# Optional model provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
CURSOR_API_KEY=

# Workspace directory
WORKSPACE_DIR=/workspace

# --- PostgreSQL (docker-compose default) ---
POSTGRES_USER=paperclip
POSTGRES_PASSWORD=paperclip
POSTGRES_DB=paperclip
POSTGRES_PORT=5432

# Optional: override app DB target. By default docker-compose points to `db` service.
# DATABASE_URL=postgres://paperclip:paperclip@db:5432/paperclip

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
